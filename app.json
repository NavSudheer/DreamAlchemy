{
  "expo": {
    "name": "Dream Alchemy",
    "slug": "DreamAlchemy",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dreamalchemy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "A Jungian dream analysis app that helps interpret your dreams using AI and Jungian psychology principles.",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "17",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Dream Alchemy needs access to your microphone to record your dream descriptions for analysis.",
        "NSSpeechRecognitionUsageDescription": "Dream Alchemy uses speech recognition to transcribe your spoken dream descriptions into text for analysis.",
        "NSPhotoLibraryUsageDescription": "Dream Alchemy needs access to your photo library to allow you to save and share dream-related images and insights.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.navford.DreamAlchemy"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.navford.DreamAlchemy"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-voice/voice"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5f2707bf-d898-46f8-8828-04d06912dd09"
      }
    }
  }
}
